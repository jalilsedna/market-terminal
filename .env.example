# Copy this file to `.env` and fill in keys as needed.
# `.env` is gitignored and must NEVER be committed.
#
# The terminal boots fine with NO keys (free providers only). Add a key only
# when you need that paid provider — see SPEC.md §3.

# --- App ---
HOST=127.0.0.1
PORT=8000
DEBUG=false

# --- Auth (REQUIRED before deploying publicly; leave blank for local dev) ---
# With BOTH of the following blank, auth is DISABLED and the terminal is open —
# fine on localhost, NEVER on a public deploy. On Railway you MUST set at least
# AUTH_TOKEN (for Alice/MCP/API) and ADMIN_PASSWORD (for the browser login).
#
# Bearer token for programmatic clients (Alice's .mcp.json, API). Generate:
#   openssl rand -hex 32
AUTH_TOKEN=
# Browser login for the /login page.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Signs session cookies; keep stable so logins survive redeploys. Generate:
#   openssl rand -hex 32
SESSION_SECRET=
# Public URL of the deployed terminal (informational; used in docs/Alice config).
PUBLIC_BASE_URL=
# Self-service sign-ups (F2). OFF by default — a public research terminal
# shouldn't let anyone register and burn the provider keys. true opens /register;
# otherwise the admin (ADMIN_*) creates accounts in the Admin tab.
REGISTRATION_OPEN=false

# Background pre-cache warmer: minutes between cache-warming cycles (0 disables).
PRECACHE_INTERVAL_MIN=30

# MCP server over HTTP (only used with `python mcp_server.py --http`). Defaults
# to 127.0.0.1:8001 (off the REST API's 8000). Set MCP_HOST=0.0.0.0 only if a
# containerized client (e.g. OpenAlice in Docker) must reach it — and only on a
# trusted network.
MCP_HOST=127.0.0.1
MCP_PORT=8001

# URL of the separate execution app (OpenAlice), framed in the Execution tab.
ALICE_URL=http://localhost:5173

# SQLite database (C2) — backs the custom watchlist + history snapshots. Default
# is under gitignored cache/data. On Railway, point this at a mounted VOLUME
# (e.g. /data/terminal.db) so the watchlist + history survive redeploys.
DB_PATH=cache/data/terminal.db

# EOD provider fallback chain for equity/ETF routes (B4). Comma-separated; the
# fetchers try each until one returns data, so a yfinance throttle/401 falls back.
# Get a FREE Tiingo key (tiingo.com); with a Polygon/Massive key too, set
# "tiingo,polygon,yfinance" for three-deep resilience.
EOD_PROVIDERS=yfinance

# --- Provider API keys (all optional) ---
FMP_API_KEY=
FRED_API_KEY=
BENZINGA_API_KEY=
INTRINIO_API_KEY=
TIINGO_API_KEY=
# Polygon.io key — Polygon rebranded to Massive.com (2025-10-30); a massive.com
# key works here unchanged (OpenBB's `polygon` provider hits api.polygon.io).
POLYGON_API_KEY=
EIA_API_KEY=
